# ─────────────────────────────────────────────────────────────
# NortPlex Backend — Environment Variables
# Copiaza in .env si completeaza valorile
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (pentru CORS si OAuth redirects)
FRONTEND_URL=http://localhost:5173

# ─── JWT ────────────────────────────────────────────────────
# Genereaza cu: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SCHIMBA_CU_UN_SECRET_RANDOM_LUNG_64_CHARS
JWT_REFRESH_SECRET=SCHIMBA_CU_UN_ALT_SECRET_RANDOM_LUNG_64_CHARS

# Access token expiry (ex: 15m, 1h)
JWT_EXPIRES_IN=1h
# Refresh token expiry (ex: 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email / SMTP ───────────────────────────────────────────
# Pentru Gmail: activeaza "App Passwords" in contul Google
# (myaccount.google.com → Security → 2FA → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Adresa care apare ca "From" in emailuri
SMTP_FROM=NortPlex <nortplex@gmail.com>

# Adresa unde primesti mesajele de la formularul de contact
CONTACT_RECEIVE_EMAIL=nortplex@gmail.com

# ─── Google OAuth ────────────────────────────────────────────
# 1. Mergi la: https://console.cloud.google.com/
# 2. Creeaza un proiect nou sau selecteaza unul existent
# 3. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Authorized redirect URIs: http://localhost:3001/api/auth/google/callback
#    (in productie: https://domeniultau.com/api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth ────────────────────────────────────────────
# 1. Mergi la: https://github.com/settings/developers
# 2. OAuth Apps → New OAuth App
# 3. Homepage URL: http://localhost:5173
# 4. Authorization callback URL: http://localhost:3001/api/auth/github/callback
#    (in productie: https://domeniultau.com/api/auth/github/callback)
GITHUB_CLIENT_ID=GITHUB_CLIENT_ID_AL_TAU
GITHUB_CLIENT_SECRET=GITHUB_CLIENT_SECRET_AL_TAU

# ─── Cookie ──────────────────────────────────────────────────
# Domeniu cookie (lasa gol pentru localhost, pune domeniu in productie)
COOKIE_DOMAIN=
